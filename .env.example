PORT=8000
BASE_URL=http://localhost:8000
LOG_LEVEL=info
CACHE_TTL=3600
CACHE_DB_PATH=data/cache.db
TMDB_API_KEY=   # opcional: cadastro gratuito em themoviedb.org

# Fontes ativas
ENABLE_APACHE_TORRENT=true
ENABLE_COMANDO_FILMES=true
ENABLE_BRAZUCA=true
ENABLE_YTS=true

# Fontes com domínio instável (ative somente após testar no seu ambiente)
ENABLE_HDR_TORRENT=false
ENABLE_MICOLEAO=false
